+    @staticmethod
+    def _parse_gpu_targets(gpu_target):
+        """Parse GPU target argument into a list of architectures.
+
+        Supports single target strings as well as semicolon/comma/space-separated
+        lists passed from CMake.
+        """
+        if isinstance(gpu_target, (list, tuple)):
+            targets = [str(t).strip() for t in gpu_target if str(t).strip()]
+            return targets if targets else ["unknown"]
+
+        target_str = str(gpu_target).strip()
+        if not target_str:
+            return ["unknown"]
+
+        targets = [t for t in re.split(r"[;,\s]+", target_str) if t]
+        return targets if targets else [target_str]
+
