#!/bin/bash -e

export PATH=/user-tools/env/jupyter/bin:$PATH
pip install -r {{ env.mount }}/meta/recipe/requirements.txt

git clone --filter=tree:0 https://github.com/eth-cscs/firecrestspawner.git
git -C firecrestspawner checkout 0.1.2
cd firecrestspawner
pip install .

curl -fsSL https://code-server.dev/install.sh | sh -s -- --method=standalone --prefix={{ env.mount }}/env/jupyter --version=4.109.2
export CODE_EXECUTABLE={{ env.mount }}/env/jupyter/bin/code-server
